{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://lockes.onrender.com/api/:path*"
    },
    {
      "source": "/sanctum/:path*",
      "destination": "https://lockes.onrender.com/sanctum/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://lockes.onrender.com/auth/:path*"
    },
    {
       "source": "/(.*)",
       "destination": "/index.html"
    }
  ]
}